<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wikisprint.server.mapper.TargetWordMapper">

    <resultMap id="TargetWordResultMap" type="TargetWordVO">
        <id     property="wordId"     column="word_id"     />
        <result property="word"       column="word"        />
        <result property="difficulty" column="difficulty"  />
        <result property="lang"       column="lang"        />
        <result property="createdAt"  column="created_at"  />
    </resultMap>

    <!-- 랜덤 제시어 1개 조회 (언어 필터) -->
    <select id="selectRandomWord" resultMap="TargetWordResultMap">
        SELECT word_id, word, difficulty, lang, created_at
        FROM target_words
        WHERE lang = #{lang}
        ORDER BY RANDOM()
        LIMIT 1
    </select>

    <!-- 랜덤 제시어 1개 조회 (언어 + 난이도 필터) -->
    <select id="selectRandomWordByDifficulty" resultMap="TargetWordResultMap">
        SELECT word_id, word, difficulty, lang, created_at
        FROM target_words
        WHERE lang = #{lang} AND difficulty = #{difficulty}
        ORDER BY RANDOM()
        LIMIT 1
    </select>

    <!-- 전체 제시어 목록 조회 -->
    <select id="selectAllWords" resultMap="TargetWordResultMap">
        SELECT word_id, word, difficulty, lang, created_at
        FROM target_words
        ORDER BY word_id
    </select>

    <!-- 제시어 추가 -->
    <insert id="insertWord">
        INSERT INTO target_words (word, difficulty, lang)
        VALUES (#{word}, #{difficulty}, #{lang})
    </insert>

    <!-- 제시어 삭제 -->
    <delete id="deleteWord">
        DELETE FROM target_words
        WHERE word_id = #{wordId}
    </delete>

    <!-- 단어로 난이도 조회 (랭킹 분류용) -->
    <select id="selectDifficultyByWord" resultType="Short">
        SELECT difficulty FROM target_words
        WHERE word = #{word}
        LIMIT 1
    </select>

</mapper>
